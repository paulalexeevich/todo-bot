# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_USER_ID=your_numeric_telegram_user_id

# LLM (claude | openai | gemini)
LLM_PROVIDER=gemini
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Reddit (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=idea-bot/1.0

# Product Hunt (https://api.producthunt.com/v2/docs)
PRODUCT_HUNT_TOKEN=

# Scheduling — UTC hour/minute for nightly discovery run
DISCOVERY_HOUR=2
DISCOVERY_MINUTE=0

# Storage
DB_PATH=./data/ideas.db

# Dashboard + data-api auth
DATA_API_KEY=your_secret_key

# GitHub knowledge repo (architecture + learning tasks)
GITHUB_TOKEN=
GITHUB_REPO=

# Location fallback
HOME_LOCATION=
